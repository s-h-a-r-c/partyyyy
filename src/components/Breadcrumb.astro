---
import { getEntry } from 'astro:content';

interface Props {
  parentSlug: string;
}
const { parentSlug } = Astro.props;
const parent = await getEntry('posts', parentSlug);
---

{parent && (
  <nav class="text-sm text-stone-500 mb-6">
    <a href="/posts" class="hover:text-stone-800 transition-colors">Posts</a>
    <span class="mx-1.5">›</span>
    <a href={`/posts/${parentSlug}`} class="hover:text-stone-800 transition-colors">{parent.data.title}</a>
  </nav>
)}
