---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const tags = [...new Set(posts.flatMap(p => p.data.tags))];
  return tags.map(tag => ({
    params: { tag },
    props: {
      posts: posts
        .filter(p => p.data.tags.includes(tag))
        .sort((a, b) => b.data.created.getTime() - a.data.created.getTime()),
    },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<Base title={`#${tag}`}>
  <div class="mb-8">
    <a href="/" class="text-sm text-stone-400 hover:text-stone-700 transition-colors">← partyyyy</a>
    <h1 class="text-xl font-bold text-stone-900 mt-2">#{tag}</h1>
    <p class="text-sm text-stone-500">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
  </div>

  <div class="grid gap-3">
    {posts.map(post => (
      <PostCard
        slug={post.id}
        title={post.data.title}
        description={post.data.description}
        tags={post.data.tags}
        created={post.data.created}
      />
    ))}
  </div>
</Base>
