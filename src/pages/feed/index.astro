---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TagList from '../../components/TagList.astro';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.created.getTime() - a.data.created.getTime());
---

<Base title="Feed">
  <section class="mb-10">
    <h1 class="text-xl font-bold text-stone-900 mb-1">Feed</h1>
    <p class="text-sm text-stone-500">
      All posts, newest first. For a non-linear view, visit the <a href="/" class="underline underline-offset-2 hover:text-stone-800 transition-colors">garden</a>.
    </p>
  </section>

  <ol class="space-y-8">
    {posts.map(post => {
      const date = post.data.created.toLocaleDateString('en-US', {
        year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC'
      });
      return (
        <li class="flex gap-6">
          <time class="text-xs text-stone-400 pt-1 w-24 shrink-0 tabular-nums">{date}</time>
          <div>
            <a href={`/posts/${post.id}`} class="font-medium text-stone-900 hover:text-stone-600 transition-colors block mb-1">
              {post.data.title}
            </a>
            <p class="text-sm text-stone-500 mb-2">{post.data.description}</p>
            <TagList tags={post.data.tags} />
          </div>
        </li>
      );
    })}
  </ol>
</Base>
