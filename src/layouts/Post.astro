---
import Base from './Base.astro';
import TagList from '../components/TagList.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SubPostList from '../components/SubPostList.astro';
import Backlinks from '../components/Backlinks.astro';

interface Props {
  title: string;
  description: string;
  tags: string[];
  created: Date;
  updated?: Date;
  parent?: string;
  slug: string;
}
const { title, description, tags, created, updated, parent, slug } = Astro.props;

const createdStr = created.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
const updatedStr = updated?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---

<Base title={title} description={description}>
  {parent && <Breadcrumb parentSlug={parent} />}

  <article>
    <header class="mb-10">
      <h1 class="text-2xl font-bold text-stone-900 leading-tight mb-3">{title}</h1>
      <p class="text-stone-500 mb-4 leading-relaxed">{description}</p>
      <TagList tags={tags} />
      <div class="mt-3 text-xs text-stone-400 space-x-3">
        <span>Published {createdStr}</span>
        {updatedStr && <span>· Updated {updatedStr}</span>}
      </div>
    </header>

    <div class="prose prose-stone prose-sm sm:prose-base max-w-none
      prose-headings:font-semibold
      prose-a:text-stone-700 prose-a:underline prose-a:underline-offset-2
      prose-a:decoration-stone-300 hover:prose-a:decoration-stone-600
      prose-hr:border-stone-200
      prose-img:rounded-lg prose-img:shadow-sm">
      <slot />
    </div>
  </article>

  <SubPostList parentSlug={slug} />
  <Backlinks currentSlug={slug} />
</Base>
